<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="APP_Proyec.Views.OrdersPage"
             Title="Pedidos">

    <CollectionView x:Name="OrdersCollection" ItemsSource="{Binding Orders}">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Frame Margin="8" Padding="8">
                    <VerticalStackLayout>
                        <Label Text="{Binding CustomerName}" FontAttributes="Bold" />
                        <Label Text="{Binding Date, StringFormat='Fecha: {0:dd/MM/yyyy}'}" />
                        <Label Text="{Binding Total, StringFormat='Total: {0:C}'}" />
                    </VerticalStackLayout>
                </Frame>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentPage>
