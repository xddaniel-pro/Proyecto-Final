<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="APP_Proyec.Views.ProductsPage"
             Title="Productos">

    <CollectionView x:Name="ProductsCollection" ItemsSource="{Binding Products}">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Frame Margin="8" Padding="8">
                    <VerticalStackLayout>
                        <Label Text="{Binding Name}" FontAttributes="Bold" />
                        <Label Text="{Binding Description}" LineBreakMode="TailTruncation" />
                        <Label Text="{Binding Price, StringFormat='Precio: {0:C}'}" />
                    </VerticalStackLayout>
                </Frame>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentPage>
