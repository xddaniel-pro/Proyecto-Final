<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="APP_Proyec.Views.TopSellingPage"
             Title="Top vendidos">

    <CollectionView x:Name="TopCollection" ItemsSource="{Binding Products}">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Frame Margin="8" Padding="8">
                    <HorizontalStackLayout>
                        <Label Text="{Binding Name}" FontAttributes="Bold" />
                        <Label Text="{Binding Sold, StringFormat='Vendidos: {0}'}" HorizontalOptions="EndAndExpand" />
                    </HorizontalStackLayout>
                </Frame>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentPage>
